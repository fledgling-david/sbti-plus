{
  "version": 2,
  "builds": [
    // 1. 强制构建Python后端
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    // 2. 强制构建Vite前端
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist",
        "buildCommand": "npm run build"
      }
    }
  ],
  "routes": [
    // 所有 /api/xxx 请求转发给Python后端
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    // 其他请求返回静态文件
    {
      "src": "/(.*)",
      "dest": "dist/index.html"
    }
  ]
}
